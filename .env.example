# VCS provider — only 'bitbucket' is implemented in Phase 1
VCS_PROVIDER=bitbucket

# Bitbucket
# Cloud:              https://api.bitbucket.org/2.0
# Self-hosted DC/Server: https://bitbucket.yourcompany.com/rest/api/1.0
BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0
BITBUCKET_WORKSPACE=your-workspace-slug
BITBUCKET_USERNAME=your-atlassian-email@company.com
BITBUCKET_TOKEN=ATATT3x...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
# MAX_RETRIES=3
# MAX_INPUT_TOKENS=150000

# Agent identity — shown in review/reply footers
# Defaults to BITBUCKET_USERNAME if not set, then 'Claude'
# AGENT_IDENTITY=

# Judge model — validates findings before posting (empty = skip judge pass)
# JUDGING_MODEL=claude-sonnet-4-6

# Reply limit — max agent reply comments per PR (0 = unlimited)
# MAX_REPLY_COMMENTS=3

# Context limits (optional — these are the defaults)
MAX_CONTEXT_FILES=20
MAX_FILE_LINES=500

# PR size thresholds (optional — 0 = disabled)
# MIN_CHANGED_FILES=0
# MAX_CHANGED_FILES=200
# MIN_CHANGED_LINES=0
# MAX_CHANGED_LINES=3000

# Diff exclusion patterns (comma-separated, default includes lock files, .json, .spec.ts)
# DIFF_EXCLUDE_PATTERNS=*.lock,package-lock.json,yarn.lock,pnpm-lock.yaml,*.json,*.spec.ts
